pipeline {
    agent {
        kubernetes {
            cloud 'DockerDesktop'
            inheritFrom 'terraform-agent'
        }
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: 'Choose the action to perform'
        )

        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'qa', 'prod'],
            description: 'Specify the environment'
        )
    }

    environment {
        TERRAFORM_DIR               = 'eks-infra-code'
        AWS_PROFILE                 = 'jhansi'
        AWS_CONFIG_FILE             = '/home/jenkins/.aws/config'
        AWS_SHARED_CREDENTIALS_FILE = '/home/jenkins/.aws/credentials'
        TF_IN_AUTOMATION            = 'true'
        TF_CLI_ARGS                 = '-no-color'

        TF_VAR_aws_profile          = credentials('aws-profile')
        TF_VAR_aws_role_arn         = credentials('aws-role-arn')
    }

    options {
        skipDefaultCheckout(true)
        disableConcurrentBuilds()
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
    }

    stages {
        stage('Code Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                container('terraform') {
                    dir("${TERRAFORM_DIR}") {
                        retry(3) {
                            timeout(time: 10, unit: 'MINUTES') {
                                sh """
                                    terraform init \
                                      -backend-config="backend/${params.ENVIRONMENT}.hcl"
                                """
                            }
                        }
                    }
                }
            }

            post {
                success {
                    slackSend(
                        color: 'good',
                        message: """
                            SUCCESS: Terraform init
                            Environment: ${params.ENVIRONMENT}
                            Job: ${env.JOB_NAME}
                            Build: #${env.BUILD_NUMBER}
                            URL: ${env.BUILD_URL}
                        """
                    )
                }

                failure {
                    slackSend(
                        color: 'danger',
                        message: """
                            FAILED: Terraform init
                            Environment: ${params.ENVIRONMENT}
                            Job: ${env.JOB_NAME}
                            Build: #${env.BUILD_NUMBER}
                            URL: ${env.BUILD_URL}
                        """
                    )
                }
            }
        }

        stage('Terraform Checks') {
            parallel {
                stage('Format Check') {
                    steps {
                        container('terraform') {
                            dir("${TERRAFORM_DIR}") {
                                sh 'terraform fmt -check -recursive'
                            }
                        }
                    }
                }

                stage('Validate') {
                    steps {
                        container('terraform') {
                            dir("${TERRAFORM_DIR}") {
                                sh 'terraform validate'
                            }
                        }
                    }
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                container('terraform') {
                    dir("${TERRAFORM_DIR}") {
                        script {
                            if (params.ACTION == 'apply') {
                                sh """
                                    terraform plan \
                                      -var-file="environments/${params.ENVIRONMENT}.tfvars" \
                                      -out=tfplan
                                """
                            } else if (params.ACTION == 'destroy') {
                                sh """
                                    terraform plan \
                                      -destroy \
                                      -var-file="environments/${params.ENVIRONMENT}.tfvars" \
                                      -out=tfplan
                                """
                            } else {
                                error("Unsupported action: ${params.ACTION}")
                            }
                        }
                    }
                }
            }
        }

        stage('Manual Approval') {
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input(
                        message: """
                            Approve Terraform ${params.ACTION}
                            for ${params.ENVIRONMENT}?
                        """,
                        ok: params.ACTION == 'apply' ? 'Apply' : 'Destroy'
                    )
                }
            }
        }

        stage('Terraform Execute') {
            steps {
                container('terraform') {
                    dir("${TERRAFORM_DIR}") {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Terraform ${params.ACTION} succeeded for ${params.ENVIRONMENT}"

            slackSend(
                color: 'good',
                message: """
                    SUCCESS: Terraform ${params.ACTION}
                    Environment: ${params.ENVIRONMENT}
                    Job: ${env.JOB_NAME}
                    Build: #${env.BUILD_NUMBER}
                    URL: ${env.BUILD_URL}
                """
            )
        }

        failure {
            echo "Terraform ${params.ACTION} failed for ${params.ENVIRONMENT}"

            slackSend(
                color: 'danger',
                message: """
                    FAILED: Terraform ${params.ACTION}
                    Environment: ${params.ENVIRONMENT}
                    Job: ${env.JOB_NAME}
                    Build: #${env.BUILD_NUMBER}
                    URL: ${env.BUILD_URL}
                """
            )
        }

        unstable {
            echo 'Pipeline is unstable'
        }

        aborted {
            echo 'Pipeline was aborted'
        }

        always {
            cleanWs()
        }
    }
}